generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Catalogue ----------

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  basePrice   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)

  hasColors  Boolean @default(false)
  hasSizes   Boolean @default(false)
  hasVolumes Boolean @default(false)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images   ProductImage[]
  colors   ProductColor[]
  sizes    ProductSize[]
  volumes  ProductVolume[]
  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  position  Int     @default(0)

  createdAt DateTime @default(now())

  @@index([productId])
}

// Vocabulaires d'options, définis par produit
model ProductColor {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  hexCode   String?

  variants ProductVariant[]

  @@unique([productId, label])
}

model ProductSize {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String

  variants ProductVariant[]

  @@unique([productId, label])
}

model ProductVolume {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String

  variants ProductVariant[]

  @@unique([productId, label])
}

// Unité de stock. Toujours au moins une par produit (variante "par défaut"
// avec colorId = sizeId = volumeId = null pour les produits sans options).
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorId String?
  color   ProductColor? @relation(fields: [colorId], references: [id], onDelete: Cascade)
  sizeId  String?
  size    ProductSize?  @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  volumeId String?
  volume   ProductVolume? @relation(fields: [volumeId], references: [id], onDelete: Cascade)

  priceOverride Decimal? @db.Decimal(10, 2)
  stockQuantity Int      @default(0)
  sku           String?  @unique

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, colorId, sizeId, volumeId])
  @@index([productId])
}

// ---------- Livraison ----------

model Wilaya {
  id            Int      @id
  name          String   @unique
  deliveryPrice Decimal  @db.Decimal(10, 2) @default(0)
  isActive      Boolean  @default(true)
  orders        Order[]
  updatedAt     DateTime @updatedAt
}

// ---------- Commandes ----------

enum OrderStatus {
  NOUVELLE
  CONFIRMEE
  EXPEDIEE
  ANNULEE
}

model Order {
  id String @id @default(cuid())

  firstName String
  lastName  String
  email     String
  phone     String

  wilayaId Int
  wilaya   Wilaya @relation(fields: [wilayaId], references: [id])

  items OrderItem[]

  deliveryFeeSnapshot Decimal @db.Decimal(10, 2)
  totalSnapshot       Decimal @db.Decimal(10, 2)

  status OrderStatus @default(NOUVELLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([wilayaId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)

  unitPriceSnapshot Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([variantId])
}

// ---------- Admin ----------

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
