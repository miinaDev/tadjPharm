generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Catalogue ----------

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  subcategories Subcategory[]
  products      Product[]
  createdAt     DateTime      @default(now())
}

// Sous-categorie optionnelle rattachee a une categorie (ex: "Coussin" dans "Orthopedique").
model Subcategory {
  id         String    @id @default(cuid())
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  products   Product[]
  createdAt  DateTime  @default(now())

  @@unique([categoryId, name])
  @@unique([categoryId, slug])
  @@index([categoryId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  basePrice   Decimal  @db.Decimal(10, 2)
  discountPercent Int  @default(0) // 0 = pas de promo (remise en % sur le prix)
  ribbonLabel String?              // etiquette optionnelle affichee sur la carte (ex: "Promo")
  isActive    Boolean  @default(true)

  hasColors  Boolean @default(false)
  hasSizes   Boolean @default(false)
  hasVolumes Boolean @default(false)

  // Suivi de stock : quand false, le produit est toujours disponible (stock ignore
  // a l'achat, pas d'alerte de stock). lowStockThreshold = seuil "stock bas" par produit.
  trackStock        Boolean @default(true)
  lowStockThreshold Int     @default(5)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  images   ProductImage[]
  colors   ProductColor[]
  sizes    ProductSize[]
  volumes  ProductVolume[]
  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([subcategoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  position  Int     @default(0)

  // Lien optionnel vers une couleur : cliquer cette couleur cote client affiche cette image.
  // SetNull : supprimer la couleur delie l'image sans la supprimer.
  colorId String?
  color   ProductColor? @relation(fields: [colorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([colorId])
}

// Vocabulaires d'options, définis par produit
model ProductColor {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  hexCode   String?

  variants ProductVariant[]
  images   ProductImage[] // images rattachees a cette couleur (lien optionnel)

  @@unique([productId, label])
}

model ProductSize {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String

  variants ProductVariant[]

  @@unique([productId, label])
}

model ProductVolume {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String

  variants ProductVariant[]

  @@unique([productId, label])
}

// Unité de stock. Toujours au moins une par produit (variante "par défaut"
// avec colorId = sizeId = volumeId = null pour les produits sans options).
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorId String?
  color   ProductColor? @relation(fields: [colorId], references: [id], onDelete: Cascade)
  sizeId  String?
  size    ProductSize?  @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  volumeId String?
  volume   ProductVolume? @relation(fields: [volumeId], references: [id], onDelete: Cascade)

  priceOverride Decimal? @db.Decimal(10, 2)
  stockQuantity Int      @default(0)
  sku           String?  @unique

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, colorId, sizeId, volumeId])
  @@index([productId])
}

// ---------- Livraison ----------

model Wilaya {
  id          Int              @id
  name        String           @unique
  homePrice   Decimal          @default(0) @db.Decimal(10, 2) // livraison à domicile (par wilaya)
  officePrice Decimal          @default(0) @db.Decimal(10, 2) // retrait bureau (unique pour tous les bureaux de la wilaya)
  isActive    Boolean          @default(true)
  bureaus     DeliveryBureau[]
  orders      Order[]
  updatedAt   DateTime         @updatedAt
}

model DeliveryBureau {
  id       String  @id @default(cuid())
  wilayaId Int
  wilaya   Wilaya  @relation(fields: [wilayaId], references: [id], onDelete: Cascade)
  name     String
  isActive Boolean @default(true)
  position Int     @default(0)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wilayaId])
}

// ---------- Commandes ----------

enum OrderStatus {
  NOUVELLE
  CONFIRMEE
  EXPEDIEE
  LIVREE
  ANNULEE
}

enum ShippingMethod {
  HOME
  OFFICE
}

model Order {
  id String @id @default(cuid())

  firstName String
  lastName  String
  email     String
  phone     String

  wilayaId          Int?
  wilaya            Wilaya? @relation(fields: [wilayaId], references: [id], onDelete: SetNull)
  wilayaNameSnapshot String @default("") // fige le nom de la wilaya pour l'historique

  shippingMethod     ShippingMethod  @default(HOME)
  address            String          @default("") // rempli uniquement si livraison à domicile
  bureauId           String?
  bureau             DeliveryBureau? @relation(fields: [bureauId], references: [id], onDelete: SetNull)
  bureauNameSnapshot String? // fige le nom du bureau pour l'historique

  items OrderItem[]

  deliveryFeeSnapshot Decimal @db.Decimal(10, 2)
  totalSnapshot       Decimal @db.Decimal(10, 2)

  status OrderStatus @default(NOUVELLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([wilayaId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int             @default(1)

  unitPriceSnapshot    Decimal @db.Decimal(10, 2)
  productNameSnapshot  String  @default("") // fige le nom du produit pour l'historique
  variantLabelSnapshot String  @default("") // fige la combinaison couleur/taille/volume

  @@index([orderId])
  @@index([variantId])
}

// ---------- Admin ----------

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
